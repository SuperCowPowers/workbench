    feature_list = TEMPLATE_PARAMS["feature_list"]
    id_column = TEMPLATE_PARAMS["id_column"]
    model_metrics_s3_path = TEMPLATE_PARAMS["model_metrics_s3_path"]
    hyperparameters = {**DEFAULT_HYPERPARAMETERS, **(TEMPLATE_PARAMS["hyperparameters"] or {})}

    # A list-valued ffn_hidden_dim sets the FFN layer count directly (chemprop
    # ignores ffn_num_layers in that case). Keep ffn_num_layers consistent so the
    # recorded/printed hyperparameters reflect the actual model.
    if isinstance(hyperparameters.get("ffn_hidden_dim"), list):
        hyperparameters["ffn_num_layers"] = len(hyperparameters["ffn_hidden_dim"])

    # butina_cutoff only applies to the butina split; null it otherwise so the
    # recorded hyperparameters don't imply an inactive knob is in effect.
    if hyperparameters.get("split_strategy") != "butina":
        hyperparameters["butina_cutoff"] = None

    if not target_columns or not isinstance(target_columns, list):
        raise ValueError("'targets' must be a non-empty list of target column names")
    n_targets = len(target_columns)

    smiles_column = _find_smiles_column(feature_list)
    extra_feature_cols = [f for f in feature_list if f != smiles_column]
    use_extra_features = len(extra_feature_cols) > 0

    print(f"Target columns ({n_targets}): {target_columns}")
    print(f"SMILES column: {smiles_column}")
    print(f"Extra features: {extra_feature_cols if use_extra_features else 'None (SMILES only)'}")
    print(f"Hyperparameters: {hyperparameters}")

    # Log foundation model configuration
    if hyperparameters.get("from_foundation"):
        freeze_epochs = hyperparameters.get("freeze_mpnn_epochs", 0)
        freeze_msg = f"MPNN frozen for {freeze_epochs} epochs" if freeze_epochs > 0 else "no freezing"
        print(f"Foundation model: {hyperparameters['from_foundation']} ({freeze_msg})")
    else:
        print("Foundation model: None (training from scratch)")

    # Load training data
    training_files = [os.path.join(args.train, f) for f in os.listdir(args.train) if f.endswith(".csv")]
    print(f"Training Files: {training_files}")
    all_df = pd.concat([pd.read_csv(f, engine="python") for f in training_files])
    check_dataframe(all_df, "training_df")

    # Clean data
    initial_count = len(all_df)
    all_df = all_df.dropna(subset=[smiles_column])
    all_df = all_df[all_df[target_columns].notna().any(axis=1)]
    if len(all_df) < initial_count:
        print(f"Dropped {initial_count - len(all_df)} rows with missing SMILES/targets")

    print(f"Data shape: {all_df.shape}")
    for tc in target_columns:
        print(f"  {tc}: {all_df[tc].notna().sum()} samples")

    # Route held-out validation rows out of training BEFORE label encoding / feature-mean fitting,
    # so nothing downstream (CV/UQ/SHAP) sees them. They're scored held-out just before save.
    from workbench.training.validation import split_validation_set

    all_df, holdout_df = split_validation_set(all_df)
    if len(holdout_df):
        print(f"Held-out validation set: {len(holdout_df)} rows (excluded from training/CV/UQ)")

    # -------------------------------------------------------------------------
    # Classification setup
    # -------------------------------------------------------------------------
    label_encoder = None
    num_classes = None
    if model_type == "classifier":
        if n_targets > 1:
            raise ValueError(
                f"Multi-task classification (got {n_targets} target columns) is not implemented in "
                "workbench's chemprop wrapper. This is a workbench limitation, not a chemprop one: "
                "chemprop supports it via BinaryClassificationFFN(n_tasks=N) and "
                "MulticlassClassificationFFN(n_classes=C, n_tasks=N). Workarounds: use a single target "
                "column, or train one single-task classifier per target."
            )
        label_encoder = LabelEncoder()
        all_df[target_columns[0]] = label_encoder.fit_transform(all_df[target_columns[0]])
        num_classes = len(label_encoder.classes_)
        print(f"Classification: {num_classes} classes: {label_encoder.classes_}")

    # -------------------------------------------------------------------------
    # Prepare features
    # -------------------------------------------------------------------------
    task = "classification" if model_type == "classifier" else "regression"
    n_extra = len(extra_feature_cols) if use_extra_features else 0

    all_extra_features, col_means = None, None
    if use_extra_features:
        all_extra_features = all_df[extra_feature_cols].values.astype(np.float32)
        col_means = np.nanmean(all_extra_features, axis=0)
        for i in range(all_extra_features.shape[1]):
            all_extra_features[np.isnan(all_extra_features[:, i]), i] = col_means[i]

    all_targets = all_df[target_columns].values.astype(np.float32)

    # ---------------------------------------------------------------------
    # Bounded-loss masks (regression only). Opt-in via hyperparameter
    # `bounded_loss=True`. By convention reads per-target boolean columns
    # {target}_gt (right-censored, true value >= y) and {target}_lt
    # (left-censored, true value <= y). When `bounded_loss` is False (the
    # default), these columns are ignored even if present in the data --
    # this keeps baseline-vs-bounded A/B comparisons clean against the
    # same FeatureSet.
    # NOTE: validation metrics and UQ calibration currently treat the
    # bound value as exact truth, which slightly understates accuracy on
    # censored rows. Revisit when adding censored-aware metrics.
    # ---------------------------------------------------------------------
    all_gt_mask, all_lt_mask = None, None
    use_bounded_loss = bool(hyperparameters.get("bounded_loss", False)) and model_type != "classifier"
    resolved_bound_columns: dict = {}
    if use_bounded_loss:
        gt_arr = np.zeros((len(all_df), n_targets), dtype=bool)
        lt_arr = np.zeros((len(all_df), n_targets), dtype=bool)
        for t_idx, t_name in enumerate(target_columns):
            gt_col, lt_col = f"{t_name}_gt", f"{t_name}_lt"
            target_meta: dict = {}
            if gt_col in all_df.columns:
                gt_arr[:, t_idx] = all_df[gt_col].fillna(0).astype(bool).values
                target_meta["gt"] = gt_col
            if lt_col in all_df.columns:
                lt_arr[:, t_idx] = all_df[lt_col].fillna(0).astype(bool).values
                target_meta["lt"] = lt_col
            if target_meta:
                resolved_bound_columns[t_name] = target_meta
        if not resolved_bound_columns:
            raise ValueError(
                f"bounded_loss=True but no bound columns found. Expected one or more of: "
                f"{[f'{t}_gt or {t}_lt' for t in target_columns]} in training data."
            )
        all_gt_mask, all_lt_mask = gt_arr, lt_arr
        for t_name, cols in resolved_bound_columns.items():
            t_idx = target_columns.index(t_name)
            gt_n = int(gt_arr[:, t_idx].sum())
            lt_n = int(lt_arr[:, t_idx].sum())
            print(f"Bounded loss for '{t_name}': gt={gt_n} ({cols.get('gt', '-')}), lt={lt_n} ({cols.get('lt', '-')})")
        print(f"Criterion -> bounded variant ({hyperparameters.get('criterion', 'mae')}).")

    # Filter invalid SMILES
    _, valid_indices = _create_molecule_datapoints(all_df[smiles_column].tolist(), all_targets, all_extra_features)
    all_df = all_df.iloc[valid_indices].reset_index(drop=True)
    all_targets = all_targets[valid_indices]
    if all_extra_features is not None:
        all_extra_features = all_extra_features[valid_indices]
    if all_gt_mask is not None:
        all_gt_mask = all_gt_mask[valid_indices]
    if all_lt_mask is not None:
        all_lt_mask = all_lt_mask[valid_indices]
    print(f"Data after SMILES validation: {all_df.shape}")

    task_weights = None
    if n_targets > 1:
        user_weights = hyperparameters.get("task_weights")
        if user_weights is not None:
            if len(user_weights) != n_targets:
                raise ValueError(f"task_weights length ({len(user_weights)}) must match n_targets ({n_targets})")
            task_weights = np.asarray(user_weights, dtype=np.float32)
            print(f"Task weights: {dict(zip(target_columns, task_weights.round(3).tolist()))}")

    # -------------------------------------------------------------------------
    # Cross-validation setup
    # -------------------------------------------------------------------------
    n_folds = hyperparameters["n_folds"]
    batch_size = hyperparameters["batch_size"]

    # Get split strategy parameters
    split_strategy = hyperparameters.get("split_strategy", "scaffold")
    butina_cutoff = hyperparameters.get("butina_cutoff", 0.4)

    # Split into folds (unified interface auto-detects 'smiles' for scaffold/butina)
    target_col = target_columns[0] if model_type == "classifier" else None
    folds = get_split_indices(
        all_df,
        n_splits=n_folds,
        strategy=split_strategy,
        target_column=target_col,
        test_size=0.2,
        random_state=42,
        butina_cutoff=butina_cutoff,
    )
    print(f"Split strategy: {split_strategy}")

    print(f"[timing] setup (imports + data load + scaffold split): {time.time() - _run_t0:.1f}s", flush=True)
    print(f"Training {'single model' if n_folds == 1 else f'{n_folds}-fold ensemble'}...")
    _train_t0 = time.time()  # [timing] total training across all folds

    # -------------------------------------------------------------------------
    # Training loop
    # -------------------------------------------------------------------------
    oof_predictions = np.full((len(all_df), n_targets), np.nan, dtype=np.float64)
    oof_proba = (
        np.full((len(all_df), num_classes), np.nan, dtype=np.float64)
        if model_type == "classifier" and num_classes
        else None
    )

    ensemble_models = []
    for fold_idx, (train_idx, val_idx) in enumerate(folds):
        print(f"\n{'='*50}")
        print(f"Fold {fold_idx + 1}/{len(folds)} - Train: {len(train_idx)}, Val: {len(val_idx)}")
        print(f"{'='*50}")

        # Split data (val_extra_raw preserves unscaled features for OOF predictions)
        df_train, df_val = all_df.iloc[train_idx].reset_index(drop=True), all_df.iloc[val_idx].reset_index(drop=True)
        train_targets, val_targets = all_targets[train_idx], all_targets[val_idx]
        train_extra = all_extra_features[train_idx] if all_extra_features is not None else None
        val_extra = all_extra_features[val_idx] if all_extra_features is not None else None
        val_extra_raw = val_extra.copy() if val_extra is not None else None
        train_gt = all_gt_mask[train_idx] if all_gt_mask is not None else None
        train_lt = all_lt_mask[train_idx] if all_lt_mask is not None else None
        val_gt = all_gt_mask[val_idx] if all_gt_mask is not None else None
        val_lt = all_lt_mask[val_idx] if all_lt_mask is not None else None

        # Create datasets
        train_dps, _ = _create_molecule_datapoints(
            df_train[smiles_column].tolist(),
            train_targets,
            train_extra,
            gt_mask=train_gt,
            lt_mask=train_lt,
        )
        val_dps, _ = _create_molecule_datapoints(
            df_val[smiles_column].tolist(),
            val_targets,
            val_extra,
            gt_mask=val_gt,
            lt_mask=val_lt,
        )
        train_dataset, val_dataset = data.MoleculeDataset(train_dps), data.MoleculeDataset(val_dps)

        # Scale features/targets
        x_d_transform = None
        if use_extra_features:
            scaler = train_dataset.normalize_inputs("X_d")
            val_dataset.normalize_inputs("X_d", scaler)
            x_d_transform = nn.ScaleTransform.from_standard_scaler(scaler)

        output_transform = None
        if model_type in ["regressor", "uq_regressor"]:
            target_scaler = train_dataset.normalize_targets()
            val_dataset.normalize_targets(target_scaler)
            output_transform = nn.UnscaleTransform.from_standard_scaler(target_scaler)

        # Cache featurized MolGraphs so dataloader workers don't re-featurize every epoch (CPU bottleneck).
        # Setting cache=True eagerly precomputes all MolGraphs; timing it both confirms the code ran and
        # measures how much featurization cost moved up front (vs. the per-batch collation floor).
        _cache_t0 = time.time()
        train_dataset.cache = True
        val_dataset.cache = True
        print(
            f"[cache] featurization cache ENABLED — {len(train_dataset)} train + {len(val_dataset)} val "
            f"MolGraphs precomputed in {time.time() - _cache_t0:.1f}s",
            flush=True,
        )

        num_workers = min(os.cpu_count() or 4, 8)  # Scale with CPUs, cap at 8
        train_loader = data.build_dataloader(
            train_dataset,
            batch_size=batch_size,
            shuffle=True,
            num_workers=num_workers,
            persistent_workers=num_workers > 0,
            pin_memory=True,
            prefetch_factor=2,
        )
        val_loader = data.build_dataloader(
            val_dataset,
            batch_size=batch_size,
            shuffle=False,
            num_workers=num_workers,
            persistent_workers=num_workers > 0,
            pin_memory=True,
            prefetch_factor=2,
        )

        # Build model
        pl.seed_everything(hyperparameters["seed"] + fold_idx)
        mpnn = build_mpnn_model(
            hyperparameters,
            task=task,
            num_classes=num_classes,
            n_targets=n_targets,
            n_extra_descriptors=n_extra,
            x_d_transform=x_d_transform,
            output_transform=output_transform,
            task_weights=task_weights,
            use_bounded_loss=use_bounded_loss,
        )

        # Train model (with optional two-phase foundation training)
        freeze_mpnn_epochs = hyperparameters.get("freeze_mpnn_epochs", 0)
        use_two_phase = hyperparameters.get("from_foundation") and freeze_mpnn_epochs > 0

        def _set_mpnn_frozen(frozen: bool):
            for param in mpnn.message_passing.parameters():
                param.requires_grad = not frozen
            for param in mpnn.agg.parameters():
                param.requires_grad = not frozen

        def _make_trainer(max_epochs: int, save_checkpoint: bool = False):
            callbacks = [
                pl.callbacks.EarlyStopping(monitor="val_loss", patience=hyperparameters["patience"], mode="min")
            ]
            if save_checkpoint:
                callbacks.append(
                    pl.callbacks.ModelCheckpoint(
                        dirpath=args.model_dir,
                        filename=f"best_{fold_idx}",
                        monitor="val_loss",
                        mode="min",
                        save_top_k=1,
                    )
                )
            return pl.Trainer(
                accelerator="auto",
                max_epochs=max_epochs,
                precision="16-mixed",
                logger=False,
                enable_progress_bar=True,
                callbacks=callbacks,
            )

        _fit_t0 = time.time()
        if use_two_phase:
            # Phase 1: Freeze MPNN, train FFN only
            print(f"Phase 1: Training with frozen MPNN for {freeze_mpnn_epochs} epochs...")
            _set_mpnn_frozen(True)
            _make_trainer(freeze_mpnn_epochs).fit(mpnn, train_loader, val_loader)

            # Phase 2: Unfreeze and fine-tune all
            print("Phase 2: Unfreezing MPNN, continuing training...")
            _set_mpnn_frozen(False)
            remaining_epochs = max(1, hyperparameters["max_epochs"] - freeze_mpnn_epochs)
            trainer = _make_trainer(remaining_epochs, save_checkpoint=True)
            trainer.fit(mpnn, train_loader, val_loader)
        else:
            trainer = _make_trainer(hyperparameters["max_epochs"], save_checkpoint=True)
            trainer.fit(mpnn, train_loader, val_loader)

        _fit_secs = time.time() - _fit_t0
        print(f"[timing] fold {fold_idx + 1} fit: {_fit_secs:.1f}s", flush=True)

        # Load best checkpoint
        if trainer.checkpoint_callback and trainer.checkpoint_callback.best_model_path:
            checkpoint = torch.load(trainer.checkpoint_callback.best_model_path, weights_only=False)
            mpnn.load_state_dict(checkpoint["state_dict"])

        mpnn.eval()
        ensemble_models.append(mpnn)

        # Out-of-fold predictions (using unscaled features - model's x_d_transform handles scaling)
        val_dps_raw, _ = _create_molecule_datapoints(df_val[smiles_column].tolist(), val_targets, val_extra_raw)
        oof_dataset = data.MoleculeDataset(val_dps_raw)
        val_loader_pred = data.build_dataloader(
            oof_dataset,
            batch_size=_safe_batch_size(len(oof_dataset), batch_size),
            shuffle=False,
            num_workers=num_workers,
            pin_memory=True,
        )

        _oof_t0 = time.time()
        with torch.inference_mode():
            fold_preds = np.concatenate([p.numpy() for p in trainer.predict(mpnn, val_loader_pred)], axis=0)
        print(f"[timing] fold {fold_idx + 1} OOF predict: {time.time() - _oof_t0:.1f}s", flush=True)
        print(f"Fold {fold_idx + 1} OOF predictions complete.", flush=True)
        if fold_preds.ndim == 3 and fold_preds.shape[1] == 1:
            fold_preds = fold_preds.squeeze(axis=1)

        if model_type == "classifier" and fold_preds.ndim == 2:
            oof_predictions[val_idx, 0] = np.argmax(fold_preds, axis=1)
            if oof_proba is not None:
                oof_proba[val_idx] = fold_preds
        else:
            if fold_preds.ndim == 1:
                fold_preds = fold_preds.reshape(-1, 1)
            oof_predictions[val_idx] = fold_preds

    print(f"[timing] total training ({len(ensemble_models)} folds): {time.time() - _train_t0:.1f}s", flush=True)
    _post_t0 = time.time()  # [timing] post-training: std + UQ + SHAP + save
    print(f"\nTraining complete! Trained {len(ensemble_models)} model(s).", flush=True)

    # -------------------------------------------------------------------------
    # Prepare validation results
    # -------------------------------------------------------------------------
    if n_folds == 1:
        val_mask = ~np.isnan(oof_predictions).all(axis=1)
        df_val = all_df[val_mask].copy()
        preds = oof_predictions[val_mask]
        y_validate = all_targets[val_mask]
        if oof_proba is not None:
            oof_proba = oof_proba[val_mask]
        val_extra_features = all_extra_features[val_mask] if all_extra_features is not None else None
        in_model_mask = ~val_mask  # single split: val rows never trained the model
    else:
        df_val = all_df.copy()
        preds = oof_predictions
        y_validate = all_targets
        val_extra_features = all_extra_features
        in_model_mask = np.ones(len(all_df), dtype=bool)  # CV: every row trained in k-1 folds

    # -------------------------------------------------------------------------
    # Compute metrics and prepare output
    # -------------------------------------------------------------------------
    if model_type == "classifier":
        class_preds = preds[:, 0].astype(int)
        target_name = target_columns[0]
        y_true_decoded = label_encoder.inverse_transform(y_validate[:, 0].astype(int))
        preds_decoded = label_encoder.inverse_transform(class_preds)

        score_df = compute_classification_metrics(y_true_decoded, preds_decoded, label_encoder.classes_, target_name)
        print_classification_metrics(score_df, target_name, label_encoder.classes_)
        print_confusion_matrix(y_true_decoded, preds_decoded, label_encoder.classes_)

        # Decode target column back to string labels (was encoded for training)
        df_val[target_name] = y_true_decoded
        df_val["prediction"] = preds_decoded
        if oof_proba is not None:
            df_val["pred_proba"] = [p.tolist() for p in oof_proba]
            df_val = expand_proba_column(df_val, label_encoder.classes_)

        # Calibrate VGMU classification confidence from ensemble probabilities
        if len(ensemble_models) > 1:
            val_dps, _ = _create_molecule_datapoints(df_val[smiles_column].tolist(), None, val_extra_features)
            cal_dataset = data.MoleculeDataset(val_dps)
            infer_batch = min(len(cal_dataset), 4096)
            cal_loader = data.build_dataloader(
                cal_dataset,
                batch_size=_safe_batch_size(len(cal_dataset), infer_batch),
                shuffle=False,
            )

            all_model_probs = []
            for m in ensemble_models:
                m.eval().to(device)
                model_preds = []
                with torch.inference_mode():
                    for batch in cal_loader:
                        bmg, V_d, X_d, *_ = batch
                        bmg.to(device)
                        V_d = V_d.to(device) if V_d is not None else None
                        X_d = X_d.to(device) if X_d is not None else None
                        output = m(bmg, V_d, X_d)
                        model_preds.append(output.detach().cpu().numpy())
                probs = np.concatenate(model_preds, axis=0)
                if probs.ndim == 3 and probs.shape[1] == 1:
                    probs = probs.squeeze(axis=1)
                all_model_probs.append(probs)

            all_probs_stack = np.stack(all_model_probs)  # (n_models, n_samples, n_classes)
            if all_probs_stack.shape[2] == 1:
                # Binary sigmoid → expand to 2-class for each model
                all_probs_stack = np.concatenate([1 - all_probs_stack, all_probs_stack], axis=2)
            avg_probs = np.mean(all_probs_stack, axis=0)
            raw_conf = compute_vgmu_confidence(avg_probs, all_probs_stack)
            classification_uq = calibrate_classification_confidence(raw_conf, y_true_decoded, preds_decoded)
            df_val["confidence"] = apply_classification_confidence(
                raw_conf, classification_uq["classification_confidence"]
            )
        else:
            classification_uq = None
        uq_model = None
        # No regression UQ on classification tasks (save_regression_uq accepts None)
        uq_dict = None
    else:
        classification_uq = None
        # Compute ensemble std using direct PyTorch inference (faster, no Trainer overhead)
        preds_std = None
        if len(ensemble_models) > 1:
            _std_t0 = time.time()
            print("Computing prediction_std from ensemble...", flush=True)
            val_dps, _ = _create_molecule_datapoints(df_val[smiles_column].tolist(), y_validate, val_extra_features)
            std_dataset = data.MoleculeDataset(val_dps)
            std_dataset.cache = True
            infer_batch = min(len(std_dataset), 4096)
            infer_workers = min(os.cpu_count() or 4, 8)
            val_loader = data.build_dataloader(
                std_dataset,
                batch_size=_safe_batch_size(len(std_dataset), infer_batch),
                shuffle=False,
                num_workers=infer_workers,
                pin_memory=True,
            )
            print(f"  Dataset ready ({len(std_dataset)} samples), running {len(ensemble_models)} models...", flush=True)

            all_ens_preds = []
            for m in ensemble_models:
                m.eval().to(device)
                model_preds = []
                with torch.inference_mode():
                    for batch in val_loader:
                        bmg, V_d, X_d, *_ = batch
                        bmg.to(device)
                        V_d = V_d.to(device) if V_d is not None else None
                        X_d = X_d.to(device) if X_d is not None else None
                        output = m(bmg, V_d, X_d)
                        model_preds.append(output.detach().cpu().numpy())
                ens_preds = np.concatenate(model_preds, axis=0)
                if ens_preds.ndim == 3 and ens_preds.shape[1] == 1:
                    ens_preds = ens_preds.squeeze(axis=1)
                all_ens_preds.append(ens_preds)
            print(f"[timing] prediction_std (ensemble inference): {time.time() - _std_t0:.1f}s", flush=True)
            preds_std = np.std(np.stack(all_ens_preds), axis=0)
            if preds_std.ndim == 1:
                preds_std = preds_std.reshape(-1, 1)
            preds_std = compress_std_outliers(preds_std)

        print(f"[timing] post-training elapsed before metrics: {time.time() - _post_t0:.1f}s", flush=True)
        print("\n--- Per-target metrics ---")
        for t_idx, t_name in enumerate(target_columns):
            valid_mask = ~np.isnan(y_validate[:, t_idx])
            if valid_mask.sum() > 0:
                metrics = compute_regression_metrics(y_validate[valid_mask, t_idx], preds[valid_mask, t_idx])
                print_regression_metrics(metrics)

            df_val[f"{t_name}_pred"] = preds[:, t_idx]
            df_val[f"{t_name}_pred_std"] = preds_std[:, t_idx] if preds_std is not None else 0.0

        # Fit both UQ models on the primary target's validation predictions.
        # Multi-target UQ is not yet supported — only the primary target gets
        # UQ treatment. Per-target {target}_pred / {target}_pred_std columns
        # remain available for downstream multi-target needs.
        print("\n" + "=" * 50)
        print("Fitting UQ models on primary target")
        print("=" * 50)

        primary = target_columns[0]
        df_val["prediction"] = df_val[f"{primary}_pred"]
        df_val["prediction_std"] = df_val[f"{primary}_pred_std"]

        uq_dict = None  # set in the valid-rows branch below; save handles None

        # Only fit UQ if we have valid primary-target rows
        valid = df_val[primary].notna()
        if valid.sum() > 0:
            val_ids = df_val.loc[valid, id_column].tolist()
            val_y = df_val.loc[valid, primary].values
            val_pred = df_val.loc[valid, f"{primary}_pred"].values
            val_std = df_val.loc[valid, f"{primary}_pred_std"].values

            # V1/V2 need a fingerprint proximity set (smiles); with smiles we fit all
            # three, otherwise just V0 (fit_regression_uq handles the prox_df=None case).
            if smiles_column in all_df.columns:
                prox_df = all_df[[id_column, smiles_column, primary]].copy()
                prox_df = prox_df.rename(columns={smiles_column: "smiles"})
                prox_df["in_model"] = in_model_mask  # see XGB template for rationale on CV folds
            else:
                prox_df = None
                print(f"No '{smiles_column}' column: fitting UQ V0 only (V1/V2 need fingerprints)")

            uq_dict = fit_regression_uq(
                y_true=val_y,
                y_pred=val_pred,
                y_std=val_std,
                val_ids=val_ids,
                prox_df=prox_df,
                id_column=id_column,
                target=primary,
                active_version=hyperparameters.get("uq_version", "v0"),
            )

            # Apply active UQ to df_val columns for validation_predictions.csv
            uq_out = uq_dict["uq_model"].predict(val_ids, val_pred, val_std)
            for col in uq_out.columns:
                df_val[col] = np.nan
                df_val.loc[valid, col] = uq_out[col].values
        else:
            print("[uq] No valid primary-target rows; skipping UQ fits.")

    # -------------------------------------------------------------------------
    # Compute SHAP values for feature importance
    # -------------------------------------------------------------------------
    # Uses PermutationExplainer with custom featurizers to measure the importance
    # of each atom/bond feature type (e.g., atomic_num, degree, bond_type).
    # Output format matches XGB/PyTorch templates: shap_importance.json,
    # shap_values.csv, and shap_feature_values.csv.
    # -------------------------------------------------------------------------
    _shap_t0 = time.time()  # [timing] SHAP phase
    print("\n" + "=" * 50, flush=True)
    print("Computing SHAP Values", flush=True)
    print("=" * 50, flush=True)
    from workbench.endpoints.chemprop_shap_utils import compute_chemprop_shap, format_shap_results

    print("[timing] SHAP imports loaded", flush=True)

    shap_values_array, shap_feature_names, shap_indices, shap_fractions = compute_chemprop_shap(
        model=ensemble_models[0],
        smiles=df_val[smiles_column].tolist(),
        extra_descriptors=val_extra_features if use_extra_features else None,
        extra_feature_names=extra_feature_cols if use_extra_features else None,
        is_classifier=model_type == "classifier",
    )
    sample_ids = df_val.iloc[shap_indices][id_column].reset_index(drop=True) if id_column in df_val.columns else None

    # Multiclass classification: shap_values_array is (n_samples, n_classes, n_features)
    # Regression (single or multi-target): shap_values_array is (n_samples, n_features)
    is_multiclass_shap = shap_values_array.ndim == 3 and model_type == "classifier"
    n_shap_classes = shap_values_array.shape[1] if is_multiclass_shap else 1

    # Limit detailed SHAP CSVs to top N features (shap_importance.json retains all)
    shap_top_n = 20

    if is_multiclass_shap:
        # Compute importance averaged across classes (matches XGB/PyTorch)
        mean_abs_shap = np.mean(np.abs(shap_values_array), axis=(0, 1))
        shap_importance = sorted(
            [(shap_feature_names[i], round(float(mean_abs_shap[i]), 6)) for i in range(len(shap_feature_names))],
            key=lambda x: x[1],
            reverse=True,
        )
        print(f"Top 5 SHAP features: {shap_importance[:5]}")

        # Save per-class SHAP CSVs (matches XGB/PyTorch pattern)
        class_labels = label_encoder.classes_.tolist()
        top_n_features = [f[0] for f in shap_importance[:shap_top_n]]
        top_n_indices = [shap_feature_names.index(f) for f in top_n_features]
        for class_idx, class_label in enumerate(class_labels):
            class_shap = shap_values_array[:, class_idx, :][:, top_n_indices]
            shap_df = pd.DataFrame(class_shap, columns=top_n_features)
            if sample_ids is not None:
                shap_df.insert(0, id_column, sample_ids)
            wr.s3.to_csv(shap_df, f"{model_metrics_s3_path}/shap_values_{class_label}.csv", index=False)
        print(f"Saved SHAP values for {len(class_labels)} classes")

        # Save feature values for SHAP plots
        # Use feature fractions (chemprop-specific) since features are atom/bond bits
        active_fractions = shap_fractions[:, top_n_indices]
        feature_vals_df = pd.DataFrame(active_fractions, columns=top_n_features)
        if sample_ids is not None:
            feature_vals_df.insert(0, id_column, sample_ids)
        wr.s3.to_csv(feature_vals_df, f"{model_metrics_s3_path}/shap_feature_values.csv", index=False)
    else:
        shap_importance, shap_values_df, feature_vals_df = format_shap_results(
            shap_values_array,
            shap_feature_names,
            shap_fractions,
            sample_ids=sample_ids,
            id_column=id_column,
            top_n=shap_top_n,
        )
        print(f"Top 5 SHAP features: {shap_importance[:5]}")
        wr.s3.to_csv(shap_values_df, f"{model_metrics_s3_path}/shap_values.csv", index=False)
        wr.s3.to_csv(feature_vals_df, f"{model_metrics_s3_path}/shap_feature_values.csv", index=False)

    save_to_s3(shap_importance, f"{model_metrics_s3_path}/shap_importance.json")
    print(f"Saved SHAP artifacts ({len(shap_indices)} samples, {len(shap_importance)} features)")
    print(f"[timing] SHAP: {time.time() - _shap_t0:.1f}s", flush=True)

    # -------------------------------------------------------------------------
    # Score the held-out validation set (honest, never-trained rows)
    # -------------------------------------------------------------------------
    # The OOF rows above are the model's standard metrics; the held-out set is an
    # independent read. Rows are marked with a `validation` column so downstream
    # tooling can separate the two; primary-target held-out MAE prints as `holdout_mae`.
    df_val["validation"] = False
    if len(holdout_df):
        print("\n" + "=" * 50)
        print(f"Scoring held-out validation set ({len(holdout_df)} rows)")
        print("=" * 50)

        # Clean held-out rows the same way training data was cleaned
        h_df = holdout_df.dropna(subset=[smiles_column]).copy()
        h_df = h_df[h_df[target_columns].notna().any(axis=1)]

        # Extra features: raw + imputed with TRAINING col_means (model's x_d_transform scales)
        h_extra = None
        if use_extra_features:
            h_extra = h_df[extra_feature_cols].values.astype(np.float32)
            for i in range(h_extra.shape[1]):
                h_extra[np.isnan(h_extra[:, i]), i] = col_means[i]

        h_dps, h_valid = _create_molecule_datapoints(h_df[smiles_column].tolist(), None, h_extra)
        h_df = h_df.iloc[h_valid].reset_index(drop=True)

        if len(h_dps):
            h_dataset = data.MoleculeDataset(h_dps)
            h_loader = data.build_dataloader(
                h_dataset, batch_size=_safe_batch_size(len(h_dataset), min(len(h_dataset), 4096)), shuffle=False
            )
            all_ens = []
            for m in ensemble_models:
                m.eval().to(device)
                model_preds = []
                with torch.inference_mode():
                    for batch in h_loader:
                        bmg, V_d, X_d, *_ = batch
                        bmg.to(device)
                        V_d = V_d.to(device) if V_d is not None else None
                        X_d = X_d.to(device) if X_d is not None else None
                        model_preds.append(m(bmg, V_d, X_d).detach().cpu().numpy())
                ens_preds = np.concatenate(model_preds, axis=0)
                if ens_preds.ndim == 3 and ens_preds.shape[1] == 1:
                    ens_preds = ens_preds.squeeze(axis=1)
                all_ens.append(ens_preds)
            h_preds = np.mean(np.stack(all_ens), axis=0)
            h_std = np.std(np.stack(all_ens), axis=0)
            if h_preds.ndim == 1:
                h_preds, h_std = h_preds.reshape(-1, 1), h_std.reshape(-1, 1)
            h_std = compress_std_outliers(h_std)

            if model_type == "classifier":
                all_probs_stack = np.stack(all_ens)  # (n_models, n_samples, n_classes or 1 sigmoid)
                if all_probs_stack.shape[2] == 1:
                    all_probs_stack = np.concatenate([1 - all_probs_stack, all_probs_stack], axis=2)
                avg_probs = np.mean(all_probs_stack, axis=0)
                h_pred = label_encoder.inverse_transform(np.argmax(avg_probs, axis=1))
                y_h_true = h_df[target_columns[0]].values
                score_df = compute_classification_metrics(y_h_true, h_pred, label_encoder.classes_, target_columns[0])
                print_classification_metrics(score_df, target_columns[0], label_encoder.classes_)
                h_out = pd.DataFrame(
                    {id_column: h_df[id_column].values, target_columns[0]: y_h_true, "prediction": h_pred}
                )
                # Carry per-class probabilities (+ confidence) so held-out rows aren't NaN in the
                # proba columns after the concat below — the downstream ROC-AUC read requires them.
                h_out["pred_proba"] = [p.tolist() for p in avg_probs]
                h_out = expand_proba_column(h_out, label_encoder.classes_)
                if classification_uq and "classification_confidence" in classification_uq:
                    raw_conf = compute_vgmu_confidence(avg_probs, all_probs_stack)
                    h_out["confidence"] = apply_classification_confidence(
                        raw_conf, classification_uq["classification_confidence"]
                    )
            else:
                h_out = pd.DataFrame({id_column: h_df[id_column].values})
                print("Held-out validation metrics (per target):")
                for t_idx, t_name in enumerate(target_columns):
                    h_out[t_name] = h_df[t_name].values
                    h_out[f"{t_name}_pred"] = h_preds[:, t_idx]
                    h_out[f"{t_name}_pred_std"] = h_std[:, t_idx]
                    mask = h_df[t_name].notna().values
                    if mask.sum() > 0:
                        metrics = compute_regression_metrics(h_df[t_name].values[mask], h_preds[mask, t_idx])
                        print_regression_metrics(metrics)
                        if t_idx == 0:
                            print(f"holdout_mae: {metrics['mae']:.3f}")
                h_out["prediction"] = h_out[f"{target_columns[0]}_pred"]
                h_out["prediction_std"] = h_out[f"{target_columns[0]}_pred_std"]

            h_out["validation"] = True
            df_val = pd.concat([df_val, h_out], ignore_index=True)

    # -------------------------------------------------------------------------
    # Save validation predictions to S3
    # -------------------------------------------------------------------------
    output_columns = [id_column] if id_column in df_val.columns else []
    output_columns += target_columns
    output_columns += [f"{t}_pred" for t in target_columns] + [f"{t}_pred_std" for t in target_columns]
    output_columns += ["prediction", "prediction_std"]
    output_columns += [
        c for c in df_val.columns if c.startswith("q_") or c.endswith("_confidence") or c == "confidence"
    ]
    output_columns += [c for c in df_val.columns if c.endswith("_proba")]
    output_columns += ["validation"]

    output_columns = [c for c in output_columns if c in df_val.columns]

    wr.s3.to_csv(df_val[output_columns], f"{model_metrics_s3_path}/validation_predictions.csv", index=False)

    # -------------------------------------------------------------------------
    # Save model artifacts
    # -------------------------------------------------------------------------
    print(f"[timing] post-training elapsed before model save: {time.time() - _post_t0:.1f}s", flush=True)
    for idx, m in enumerate(ensemble_models):
        # Move back to CPU before saving so the artifact loads on CPU-only endpoints
        # (post-training inference above may have moved the model to GPU).
        models.save_model(os.path.join(args.model_dir, f"chemprop_model_{idx}.pt"), m.cpu())
    print(f"Saved {len(ensemble_models)} model(s)")

    # Clean up checkpoints
    for ckpt in glob.glob(os.path.join(args.model_dir, "best_*.ckpt")):
        os.remove(ckpt)

    ensemble_metadata = {
        "n_ensemble": len(ensemble_models),
        "n_folds": n_folds,
        "target_columns": target_columns,
        # Foundation model provenance (for tracking/reproducibility)
        "from_foundation": hyperparameters.get("from_foundation", None),
        "freeze_mpnn_epochs": hyperparameters.get("freeze_mpnn_epochs", 0),
        # Bounded-loss censoring config (None when no mask columns were found)
        "bound_columns": resolved_bound_columns if use_bounded_loss else None,
    }
    joblib.dump(ensemble_metadata, os.path.join(args.model_dir, "ensemble_metadata.joblib"))

    # Save both UQ artifacts when fitted — bundle carries V0 + V1 side-by-side.
    save_regression_uq(uq_dict, args.model_dir)
    if classification_uq is not None:
        save_classification_uq(classification_uq, args.model_dir)

    with open(os.path.join(args.model_dir, "hyperparameters.json"), "w") as f:
        json.dump(hyperparameters, f, indent=2)

    if label_encoder:
        joblib.dump(label_encoder, os.path.join(args.model_dir, "label_encoder.joblib"))

    if use_extra_features:
        joblib.dump(
            {"extra_feature_cols": extra_feature_cols, "col_means": col_means.tolist()},
            os.path.join(args.model_dir, "feature_metadata.joblib"),
        )
        print(f"Saved feature metadata for {len(extra_feature_cols)} extra features")

    print(f"[timing] total post-training: {time.time() - _post_t0:.1f}s", flush=True)
    print(f"[timing] total run: {time.time() - _run_t0:.1f}s", flush=True)

    print(f"\nModel training complete! Artifacts saved to {args.model_dir}")
