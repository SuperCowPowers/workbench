# Endpoint runtime deps for the base inference image.
# Serves sklearn/xgboost models + feature endpoints that compute mordred
# descriptors. This is a strict subset of `pip install workbench` — no
# sagemaker SDK, no orchestration clients, no UI.
#
# Version floors mirror pyproject.toml (workbench's API envelope) so this
# image stays compatible with the workbench code that gets installed
# --no-deps in the next Dockerfile layer.

boto3 >= 1.42.2
botocore >= 1.42.2
awswrangler >= 3.4.0
requests >= 2.26.0
pandas >= 2.2.1, < 3.0
scikit-learn >= 1.5.2
xgboost-cpu >= 3.0.3  # same `import xgboost` API; skips the ~400MB bundled CUDA payload of the default `xgboost`
joblib >= 1.3.2
rdkit >= 2026.3.1
mordredcommunity >= 2.0.6

# GFN2-xTB conformer energies for Boltzmann reweighting of 3D descriptors
# (mol_descriptors_3d.get_conformer_energies). Ships cp312 manylinux wheels;
# pulls cffi transitively. numpy already constrained by the locked deps.
tblite >= 0.6.0

# Endpoint server (image-specific, not in workbench main)
fastapi
uvicorn
