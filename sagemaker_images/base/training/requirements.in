# Training-time deps for the base training image.
# Runs sklearn/xgboost training jobs under SageMaker's orchestration.
# Strict subset of `pip install workbench` — no sagemaker SDK, no
# orchestration clients, no serving stack.
#
# Version floors mirror pyproject.toml (workbench's API envelope) so this
# image stays compatible with the workbench code that gets installed
# --no-deps in the next Dockerfile layer.

boto3 >= 1.42.2
botocore >= 1.42.2
awswrangler >= 3.4.0
requests >= 2.26.0
pandas >= 2.2.1, < 3.0
scikit-learn >= 1.5.2
xgboost-cpu >= 3.0.3  # same `import xgboost` API; skips the ~400MB bundled CUDA payload of the default `xgboost`
joblib >= 1.3.2
rdkit >= 2026.3.1
mordredcommunity >= 2.0.6
